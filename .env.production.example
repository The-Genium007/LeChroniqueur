# Le Chroniqueur — Production environment
# Copy this file to .env and fill in the values.
# Or use the install script: curl -fsSL .../install.sh | bash

# ─── REQUIRED (3 values) ───

# Discord bot token
# Get it at: https://discord.com/developers/applications > Bot > Token
DISCORD_TOKEN=

# Encryption key for API secrets stored in the database
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=

# Public URL where Postiz is accessible (with HTTPS for TikTok support)
# Examples: https://postiz.mydomain.com  or  http://my-vps:4007
POSTIZ_URL=

# ─── AUTO-GENERATED (do not edit unless you know what you're doing) ───

# Postiz JWT signing key (generated by install.sh)
POSTIZ_JWT_SIGNING_KEY=

# Local port for Postiz web UI
POSTIZ_PORT=4007

# ─── SOCIAL MEDIA (configured during Discord onboarding) ───
# These are stored in postiz-social.env, not here.
# The bot fills them in automatically when you configure platforms.
