# Le Chroniqueur — Production environment
# Copy this file to .env and fill in the values.
# Or use the install script: curl -fsSL .../install.sh | bash

# ─── REQUIRED ───

# Discord bot token
# Get it at: https://discord.com/developers/applications > Bot > Token
DISCORD_TOKEN=

# Encryption key for API secrets stored in the database
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=

# Public URL where Postiz is accessible
# Set automatically from POSTIZ_DOMAIN if provided, otherwise set manually.
# Examples: https://postiz.mydomain.com  or  http://my-vps:4007
POSTIZ_URL=

# Postiz internal URL — same as POSTIZ_URL in dev (in prod, uses Docker hostname)
POSTIZ_INTERNAL_URL=http://localhost:5100

# ─── HTTPS / TikTok (optional) ───

# Domain name pointing to this server (enables Caddy reverse proxy + Let's Encrypt auto-HTTPS)
# Example: postiz.mydomain.com
# When set: POSTIZ_URL should be https://<domain>, TikTok OAuth works
# When empty: Postiz is served on POSTIZ_PORT via HTTP (no TikTok)
# To activate: docker compose --profile https up -d
POSTIZ_DOMAIN=

# ─── AUTO-GENERATED (do not edit unless you know what you're doing) ───

# Postiz JWT signing key (generated by install.sh)
POSTIZ_JWT_SIGNING_KEY=

# Local port for Postiz web UI (also serves as HTTP fallback when Caddy is active)
POSTIZ_PORT=4007

# ─── OPTIONAL ───

# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ─── SOCIAL MEDIA (configured during Discord onboarding) ───
# These are stored in postiz-social.env, not here.
# The bot fills them in automatically when you configure platforms.
