{
  "name": "tumulte-bot",
  "version": "0.1.0",
  "description": "Bot Discord autonome — veille, contenu IA et publication pour Le Chroniqueur (Tumulte)",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --env-file-if-exists=.env.dev --import tsx/esm --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/core/migrate.ts",
    "reset:onboarding": "tsx scripts/reset-onboarding.ts",
    "reset:all": "tsx scripts/reset-all.ts",
    "cli": "tsx scripts/dev-cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.46.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^11.8.0",
    "discord.js": "^14.25.1",
    "jsdom": "^29.0.1",
    "linkedom": "^0.18.12",
    "node-cron": "^3.0.3",
    "openai": "^6.33.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.34.5",
    "youtube-transcript": "^1.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/sharp": "^0.31.1",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.1.0"
  }
}
