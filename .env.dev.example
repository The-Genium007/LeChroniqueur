# Le Chroniqueur — Development environment
# Copy this file to .env.dev and fill in the values.
# The bot runs natively (npm run dev), Docker provides external services.
#
# Start services:  docker compose -f docker-compose.dev.yml up -d
# Start bot:       npm run dev

# ─── REQUIRED ───

# Discord bot token
# Get it at: https://discord.com/developers/applications > Bot > Token
DISCORD_TOKEN=

# Encryption key for API secrets stored in the database
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=

# ─── LOCAL SERVICES (match docker-compose.dev.yml ports) ───

# SearXNG — exposed on port 8888 in dev compose
SEARXNG_URL=http://localhost:8888

# Postiz — exposed on port 5100 in dev compose
POSTIZ_URL=http://localhost:5100

# Postiz internal URL — same as POSTIZ_URL in dev (in prod, uses Docker hostname)
POSTIZ_INTERNAL_URL=http://localhost:5100

# ─── HTTPS / TikTok (not needed for local dev) ───

POSTIZ_DOMAIN=

# ─── AUTO-GENERATED ───

POSTIZ_JWT_SIGNING_KEY=
POSTIZ_PORT=5100

# ─── DEV OPTIONS ───

# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=debug

# Run without Discord connection (CLI mode)
DRY_RUN=false

# Use mock API responses instead of real Anthropic/SearXNG calls
MOCK_APIS=false

# ─── SOCIAL MEDIA (configured during Discord onboarding) ───
# These are stored in postiz-social.env, not here.
# The bot fills them in automatically when you configure platforms.
NODE_ENV=development